# roles/app_deploy/templates/docker-compose.yml.j2
# Docker Compose configuration for homelab
# Generated by Ansible - do not edit manually

version: "3.8"

services:
  jenkins:
    container_name: jenkins_server
    build:
      context: ./jenkins
      dockerfile: Dockerfile
    user: jenkins
    restart: unless-stopped
    ports:
      - "{{ jenkins_port }}:8080"
      - "{{ jenkins_jnlp_port | default('50000') }}:50000"
    volumes:
      - "{{ appdata_dir }}/jenkins_home:/var/jenkins_home"
      - /var/run/docker.sock:/var/run/docker.sock
      - "{{ tftp_dir }}/coreboot:/srv/tftp/coreboot"
    group_add:
      - "{{ docker_gid }}"

  jellyfin:
    image: lscr.io/linuxserver/jellyfin:latest
    container_name: jellyfin
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/jellyfin:/config"
      - "{{ media_dir }}:/data"
    ports:
      - "{{ jellyfin_port }}:8096"
    devices:
      - /dev/dri:/dev/dri
    group_add:
      - "{{ render_gid }}"
    restart: unless-stopped

  gluetun:
    image: qmcgaw/gluetun
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      - VPN_SERVICE_PROVIDER={{ vpn_provider }}
      - VPN_TYPE=wireguard
      - WIREGUARD_PRIVATE_KEY={{ wireguard_key }}
      - WIREGUARD_ADDRESSES={{ wireguard_addresses }}
      - SERVER_COUNTRIES={{ vpn_country }}
    ports:
      - "{{ qbittorrent_port }}:8080"
      - "{{ torrent_tcp_port | default('6881') }}:6881"
      - "{{ torrent_udp_port | default('6881') }}:6881/udp"
    restart: unless-stopped

  qbittorrent:
    image: lscr.io/linuxserver/qbittorrent:latest
    container_name: qbittorrent
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
      - WEBUI_PORT=8080
    volumes:
      - "{{ appdata_dir }}/qbittorrent:/config"
      - "{{ media_dir }}:/data"
    network_mode: "service:gluetun"
    depends_on:
      - gluetun
    restart: unless-stopped

  sonarr:
    image: lscr.io/linuxserver/sonarr:latest
    container_name: sonarr
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/sonarr:/config"
      - "{{ media_dir }}:/data"
    ports:
      - "{{ sonarr_port }}:8989"
    restart: unless-stopped

  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/prowlarr:/config"
    ports:
      - "{{ prowlarr_port | default('9696') }}:9696"
    restart: unless-stopped

  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/radarr:/config"
      - "{{ media_dir }}:/data"
    ports:
      - "{{ radarr_port | default('7878') }}:7878"
    restart: unless-stopped

  bazarr:
    image: lscr.io/linuxserver/bazarr:latest
    container_name: bazarr
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/bazarr:/config"
      - "{{ media_dir }}:/data"
    ports:
      - "{{ bazarr_port | default('6767') }}:6767"
    restart: unless-stopped

  lidarr:
    image: lscr.io/linuxserver/lidarr:latest
    container_name: lidarr
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/lidarr:/config"
      - "{{ media_dir }}:/data"
    ports:
      - "{{ lidarr_port | default('8686') }}:8686"
    restart: unless-stopped

  syncthing:
    image: lscr.io/linuxserver/syncthing:latest
    container_name: syncthing
    environment:
      - PUID={{ common_puid }}
      - PGID={{ common_pgid }}
      - TZ={{ common_tz }}
    volumes:
      - "{{ appdata_dir }}/syncthing:/config"
      - "{{ syncthing_data_dir }}:/syncthing"
    ports:
      - "{{ syncthing_ui_port | default('8384') }}:8384"
      - "{{ syncthing_tcp_port | default('22000') }}:22000/tcp"
      - "{{ syncthing_udp_port | default('22000') }}:22000/udp"
      - "{{ syncthing_discovery_port | default('21027') }}:21027/udp"
    restart: unless-stopped

  miniflux:
    image: miniflux/miniflux:latest
    container_name: miniflux
    ports:
      - "{{ miniflux_port | default('8050') }}:8080"
    depends_on:
      postgres:
        condition: service_healthy
    environment:
      - DATABASE_URL=postgres://{{ miniflux_db_user }}:{{ miniflux_db_password }}@postgres/{{ miniflux_db_name }}?sslmode=disable
      - RUN_MIGRATIONS=1
      - CREATE_ADMIN=1
      - ADMIN_USERNAME={{ miniflux_admin_user }}
      - ADMIN_PASSWORD={{ miniflux_admin_password }}
      
  postgres:
    image: postgres:15
    container_name: postgres
    environment:
      - POSTGRES_USER={{ miniflux_db_user }}
      - POSTGRES_PASSWORD={{ miniflux_db_password }}
      - POSTGRES_DB={{ miniflux_db_name }}
    volumes:
      - miniflux-postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ miniflux_db_user }} -d {{ miniflux_db_name }}"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  miniflux-postgres: